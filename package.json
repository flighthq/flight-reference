{
  "name": "flight-reference",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone reference harness for Flight scenarios and capture utilities.",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "tsx scripts/openfl-shims.ts",
    "dev": "vite",
    "prebuild:reference": "tsx scripts/openfl-shims.ts",
    "build:capture": "npm run build --workspace @flighthq/capture",
    "build:reference": "vite build",
    "build": "npm run build:capture && npm run build:reference",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "oxlint --max-warnings=0",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "fix": "npm run lint:fix && npm run format",
    "stage:openfl-sample-assets": "tsx scripts/stage-openfl-sample-assets.ts",
    "ci": "npm run check",
    "prepare": "husky",
    "test": "npm run test --workspace @flighthq/capture",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && npm run typecheck --workspace @flighthq/capture",
    "prepush": "tsx scripts/prepush.ts",
    "capture": "tsx scripts/capture.ts",
    "capture:update": "tsx scripts/capture.ts --update-baseline",
    "capture:check": "tsx scripts/capture.ts --fail-on-error",
    "test:e2e": "npx playwright test",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build"
  },
  "dependencies": {
    "openfl": "^9.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "starling-framework": "^2.8.0",
    "stats-js": "^1.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "picocolors": "^1.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vite": "^7.0.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "oxlint --fix --max-warnings=0 --no-error-on-unmatched-pattern",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ],
    "**/*.{css,html,json,md}": "oxfmt --write --no-error-on-unmatched-pattern"
  }
}
