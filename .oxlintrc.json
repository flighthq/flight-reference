{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/target/**",
    "**/node_modules/**",
    "**/.git/**",
    "**/.idea/**",
    "**/.vscode/**",
    "**/.claude/**",
    "**/.quimby/**",
    "**/worktrees/**",
    "reference/**",
    "**/src/wasm/**",
    "**/docs/**",
    "incoming/**",
    "tools/agents/**"
  ],
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "typescript/consistent-type-imports": "error",
    "typescript/no-empty-object-type": ["error", { "allowInterfaces": "with-single-extends" }],
    "typescript/no-namespace": "off",
    "import/no-relative-parent-imports": "error",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@flighthq/sdk",
            "message": "Import from specific packages directly. @flighthq/sdk is only for use in examples."
          }
        ]
      }
    ],
    "unicorn/no-new-array": "off",
    "unicorn/no-useless-spread": "off",
    "unicorn/prefer-module": "off"
  },
  "overrides": [
    {
      "files": ["packages/types/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@*/*"],
                "message": "Scoped imports are not allowed. Please avoid using @scope/pkg."
              }
            ]
          }
        ]
      }
    },
    {
      "files": [
        "packages/api/**/*.{ts,tsx}",
        "functional/**",
        "reference/**",
        "tools/**/*.{ts,tsx}",
        "tools/size/**",
        "**/vite*.config*.ts",
        "**/vitest*.config*.ts"
      ],
      "rules": {
        "import/no-relative-parent-imports": "off"
      }
    },
    {
      "files": ["**/scripts/**"],
      "rules": {
        "no-console": "off",
        "import/no-relative-parent-imports": "off"
      }
    },
    {
      "files": ["**/*.test.{ts,tsx}"],
      "rules": {
        "typescript/no-explicit-any": "off",
        "no-unused-vars": "off",
        "no-console": "off",
        "oxc/erasing-op": "off"
      }
    },
    {
      "files": ["packages/*/src/**/*.{ts,tsx}"],
      "rules": {
        "import/consistent-type-specifier-style": ["error", "prefer-top-level"],
        "no-warning-comments": ["error", { "terms": ["todo", "fixme", "hack", "xxx"], "location": "anywhere" }]
      }
    },
    {
      "files": [
        "apps/**/*.{ts,tsx}",
        "examples/**/*.{ts,tsx}",
        "tools/**/*.{ts,tsx}",
        "functional/**/*.{ts,tsx}",
        "reference/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
