{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSameLine": true,
  "proseWrap": "never",
  "embeddedLanguageFormatting": "auto",
  "sortPackageJson": false,
  "ignorePatterns": ["OVERVIEW.md", "**/src/wasm/", "tools/agents/", "**/*.toml"]
}
